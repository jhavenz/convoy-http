{
    "name": "convoy/http",
    "description": "HTTP server framework for Convoy",
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.4",
        "convoy/core": "^1.0",
        "react/http": "^1.10"
    },
    "suggest": {
        "symfony/runtime": "For Symfony Runtime integration via ConvoyHttpRunner",
        "convoy/stream": "For streaming responses",
        "convoy/parallel": "For worker process parallelism in request handlers"
    },
    "autoload": {
        "psr-4": {
            "Convoy\\Http\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Convoy\\Http\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
